# =============================================================================
# OpenClaw Health Fitness Agent — Environment Configuration
# =============================================================================
# Copy to .env and fill in your values:  cp .env.example .env
# NEVER commit .env — it contains secrets.
# =============================================================================

# --- Data Storage -----------------------------------------------------------
# Where health data JSON files live (absolute path).
# The dashboard container mounts this read-only.
HEALTH_FITNESS_DATA_FOLDER=/path/to/your/data/folder

# --- Integrations ------------------------------------------------------------
# Zepp (sleep/activity tracker)
ZEPP_USER=your_email@example.com
ZEPP_PASSWORD=your_password_here

# Google Health Connect
GOOGLE_DRIVE_EMAIL=your_email@gmail.com
HEALTH_CONNECT_BACKUP_DIR=/path/to/health_connect/backup

# --- Dashboard ---------------------------------------------------------------
DASHBOARD_PORT=8765
TZ=Europe/Berlin

# --- Agent -------------------------------------------------------------------
# Height/weight/goals are in data/config.json, not here.
# Only secrets and paths belong in .env.
